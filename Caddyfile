# Automatic HTTPS: Caddy obtains + renews a Let's Encrypt cert for {$DOMAIN},
# redirects HTTP->HTTPS, and reverse-proxies to the app container.
# With DOMAIN=localhost, Caddy serves a local internal-CA cert instead.

{
	# ACME account email (optional but recommended for expiry notices).
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	# The app trusts both headers (TRUST_PROXY=1), so overwrite whatever the
	# client sent. Caddy appends to X-Forwarded-For and the app reads the first
	# entry, so without this anyone can forge their rate-limit bucket.
	reverse_proxy app:3800 {
		header_up X-Forwarded-For {remote_host}
		header_up -CF-IPCountry
	}
}

# Behind Cloudflare: swap the two header_up lines for
# `header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}` and let
# CF-IPCountry through. Only safe if the origin refuses non-Cloudflare traffic.
