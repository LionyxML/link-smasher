# Copy to .env and edit. `.env` is gitignored — keep real secrets out of git.
#   cp .env.example .env

# Public hostname Caddy serves. Must be a real domain pointed at this host for
# Let's Encrypt to issue a cert. Use "localhost" for local testing (internal CA).
DOMAIN=short.example.com

# Email for the Let's Encrypt/ACME account (expiry notices). Optional for localhost.
ACME_EMAIL=you@example.com

# Admin credentials for the /list page (Basic Auth). Required — no default password.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# --- Optional overrides (safe defaults if omitted) ---
# RATE_LIMIT=on            # set to off to disable per-IP rate limiting
# RATE_LIMIT_MAX=10        # allowed POST /register per IP per window
# RATE_LIMIT_WINDOW=60     # window length in seconds
# MAX_BODY=8192            # max request body size in bytes
